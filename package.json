{
  "name": "hp-plugin-wordpress",
  "version": "0.0.3",
  "description": "Naba HockeyData Wordpress plugin.",
  "type": "module",
  "lastDependencyUpdate": "31.03.2026",
  "scripts": {
    "release": "node update-version.js",
    "release:commit": "git commit -am \"Release v$npm_package_version\"",
    "release:tag": "git tag v$npm_package_version && git push origin tag v$npm_package_version",
    "build": "npm run frontend:setup && npm run frontend:copy",
    "frontend:setup": "npm run frontend:check && npm run frontend:cleanup",
    "frontend:check": "mkdir -p frontend",
    "frontend:cleanup": "rm -rf frontend/*",
    "frontend:copy": "cp -R node_modules/@naba-network/hd-vue-gamecenter/dist/* frontend/",
    "frontend:update": "npm install @naba-network/hd-vue-gamecenter@latest",
    "test": "composer cs-check && composer phpstan && composer test",
    "test:fix": "composer cs-fix",
    "test:unit": "vendor/bin/phpunit"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:naba-network/hp-plugin-wordpress.git"
  },
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "keywords": [
    "vue",
    "vuejs",
    "valantic"
  ],
  "author": "Nachbauer GmbH",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/naba-network/hp-plugin-wordpress/issues"
  },
  "homepage": "https://github.com/naba-network/hp-plugin-wordpress",
  "dependencies": {
    "@naba-network/hd-vue-gamecenter": "^5.0.4"
  }
}
